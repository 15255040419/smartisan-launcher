<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/smt_dialog_bg_full">

    <!-- Title Bar -->
    <TextView
        android:id="@id/custom_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/smt_dialog_header"
        android:gravity="center"
        android:text="检查更新"
        android:textColor="#5C5C5C"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="300dp"
        android:padding="24dp">
        <TextView
            android:id="@id/custom_dialog_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="正在检查新版本..."
            android:textColor="#5C5C5C"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.3" />
    </ScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:background="#D1D1D1" />

    <!-- Buttons Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:orientation="horizontal"
        android:background="@drawable/smt_dialog_footer">

        <Button
            android:id="@id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/smt_dialog_btn_left"
            android:text="取消"
            android:textColor="#5C5C5C"
            android:textSize="16sp" />

        <View
            android:layout_width="1px"
            android:layout_height="match_parent"
            android:background="#D1D1D1" />

        <Button
            android:id="@id/btn_update"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/smt_dialog_btn_right"
            android:text="立即下载"
            android:textColor="#3D85C6"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
